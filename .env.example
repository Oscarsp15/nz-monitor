# ─── App ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=cambia-esto-por-una-clave-larga-aleatoria
JWT_EXPIRE_MINUTES=480

# ─── Base local (SQLite) ───────────────────────────────
DATABASE_URL=sqlite:///./data/nzmonitor.db

# ─── Netezza (nzpy, conector Python puro) ──────────────
NETEZZA_HOST=tu-host-netezza
NETEZZA_PORT=5480                 # puerto por defecto de Netezza
NETEZZA_SECURITY_LEVEL=0          # 0=preferUnsecured 1=preferSecured 3=requireSecured
NETEZZA_QUERY_TIMEOUT=30          # timeout por query (seg) — OBLIGATORIO
NETEZZA_POOL_MAX_SIZE=5
# (Credenciales reales se guardan cifradas en la BD local, no aquí)

# ─── Recolector ────────────────────────────────────────
COLLECTOR_HEALTH_INTERVAL_SECONDS=90      # salud de conexiones
COLLECTOR_ALERTS_INTERVAL_SECONDS=180     # alertas (disco SFTP, etc.)
COLLECTOR_SPACE_INTERVAL_SECONDS=300      # overview de espacio por BD

# ─── Caché / EventBus (backend enchufable) ─────────────
CACHE_BACKEND=memory   # memory | redis
EVENTBUS_BACKEND=memory # memory | redis
LIVE_QUERY_CACHE_SECONDS=300  # caché de las vistas "en vivo" (lo salta ?fresh=true)

# ─── Redis (SOLO si CACHE_BACKEND/EVENTBUS = redis) ────
# REDIS_URL=redis://localhost:6379/0
